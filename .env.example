# ==========================================
# ENTERPRISE SECURITY & SCALING ENVIRONMENT
# ==========================================

# 1. DATABASE (Supabase / Postgres)
# Replace this with your production connection pooled PostgreSQL string
DATABASE_URL="postgresql://user:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 2. ADMIN AUTHENTICATION
# Replace this with a strong, bcrypt hashed password in production, or a strong plain string if hashing is done at runtime.
ADMIN_PASSWORD="StarlineAdmin2026_Secure"

# 3. RATE LIMITING (Upstash Redis)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-upstash-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# 4. CAPTCHA PROTECTION (Google reCAPTCHA v3 or Cloudflare Turnstile)
# Get these from your provider
NEXT_PUBLIC_CAPTCHA_SITE_KEY="your-public-site-key"
CAPTCHA_SECRET_KEY="your-secret-key"
